    /**
     * 从本地扫描已下载的版本
     */
    private void loadLocalVersions() {
SwingUtilities.invokeLater(()->{
            versionModel.removeAllElements();
            
            try {
                if (Files.exists(VERSIONS_DIR)) {
                    Files.list(VERSIONS_DIR)
                        .filter(Files::isDirectory)
                        .map(p -> p.getFileName().toString())
                        .sorted(Comparator.reverseOrder())
                        .forEach(v -> versionModel.addElement(new VersionInfo(v, true)));
                }
                log("本地版本扫描完成");
            } catch (IOException e) {
                log("扫描本地版本失败: " + e.getMessage());
            }
        });
    }
    
    /**
     * 从Mojang服务器获取版本列表
     */
    private void fetchRemoteVersions() {
        executor.submit(() -> {
            try {
                log("正在获取远程版本列表...");
                String json = downloadString(VERSION_MANIFEST_URL);
                VersionManifest manifest = gson.fromJson(json, VersionManifest.class);
                
                SwingUtilities.invokeLater(() -> {
                    // 添加远程版本（标记为未下载）
                    Set<String> localVersions = new HashSet<>();
                    for (int i = 0; i < versionModel.getSize(); i++) {
                        localVersions.add(versionModel.getElementAt(i).id);
                    }
                    
                    for (VersionManifestEntry entry : manifest.versions) {
                        if (!localVersions.contains(entry.id)) {
                            versionModel.addElement(new VersionInfo(entry.id, false));
                        }
                    }
                    log("远程版本列表获取完成，共 " + manifest.versions.size() + " 个版本");
                });
            } catch (Exception e) {
                log("获取远程版本失败: " + e.getMessage());
            }
        });
    }
    
    private void refreshVersions() {
        loadLocalVersions();
        fetchRemoteVersions();
    }
    
    // ==================== 下载系统 ====================
    
    /**
     * 下载选中的版本（包括JSON、客户端Jar、库文件、资源文件）
     */
    private void downloadSelectedVersion() {
        VersionInfo version = (VersionInfo) versionCombo.getSelectedItem();
        if (version == null) {
            JOptionPane.showMessageDialog(this, "请先选择一个版本");
            return;
        }
        if (version.isLocal) {
            JOptionPane.showMessageDialog(this, "该版本已存在本地");
            return;
        }
        
        executor.submit(() -> {
            try {
                setStatus("正在下载版本: " + version.id);
                setProgress(0);
                
                // 1. 下载版本JSON
                String versionJson = downloadVersionJson(version.id);
                setProgress(10);
                
                // 2. 解析版本信息
                VersionDetail detail = gson.fromJson(versionJson, VersionDetail.class);
                
                // 3. 创建版本目录
                Path versionDir = VERSIONS_DIR.resolve(version.id);
                Files.createDirectories(versionDir);
                
                // 4. 保存版本JSON
                Files.write(versionDir.resolve(version.id + ".json"), versionJson.getBytes());
                
                // 5. 下载客户端Jar
                setStatus("下载客户端...");
                downloadFile(detail.downloads.client.url, versionDir.resolve(version.id + ".jar"));
                setProgress(30);
                
                // 6. 下载库文件
                setStatus("下载库文件...");
                downloadLibraries(detail);
                setProgress(60);
                
                // 7. 下载资源文件
                setStatus("下载资源文件...");
                downloadAssets(detail);
                setProgress(90);
                
                // 8. 解压 natives
                extractNatives(detail, version.id);
                setProgress(100);
                
                // 标记为本地版本
                SwingUtilities.invokeLater(() -> {
                    version.isLocal = true;
                    versionCombo.repaint();
                    setStatus("下载完成: " + version.id);
                    JOptionPane.showMessageDialog(this, "版本下载完成！");
                });
                
            } catch (Exception e) {
                log("下载失败: " + e.getMessage());
                e.printStackTrace();
                setStatus("下载失败");
            }
        });
    }
    
    private String downloadVersionJson(String versionId) throws IOException {
        // 先从manifest找到版本URL
        String manifestJson = downloadString(VERSION_MANIFEST_URL);
        VersionManifest manifest = gson.fromJson(manifestJson, VersionManifest.class);
        
        String versionUrl = null;
        for (VersionManifestEntry entry : manifest.versions) {
            if (entry.id.equals(versionId)) {
                versionUrl = entry.url;
                break;
            }
        }
        
        if (versionUrl == null) {
            throw new IOException("未找到版本: " + versionId);
        }
        
        return downloadString(versionUrl);
    }
    
    private void downloadLibraries(VersionDetail detail) throws IOException {
        int total = detail.libraries.size();
        int current = 0;
        
        for (Library lib : detail.libraries) {
            // 检查规则（如只允许特定OS）
            if (!checkRules(lib.rules)) continue;
            
            // 解析下载路径
            String path = lib.downloads.artifact.path;
            String url = lib.downloads.artifact.url;
            if (url == null || url.isEmpty()) {
                url = LIBRARY_BASE_URL + path;
            }
            
            Path target = LIBRARIES_DIR.resolve(path);
            if (!Files.exists(target)) {
                Files.createDirectories(target.getParent());
                try {
                    downloadFile(url, target);
                } catch (IOException e) {
                    log("库下载失败（跳过）: " + path);
                }
            }
            
            current++;
            setProgress(30 + (current * 30 / total));
        }
    }
    
    private void downloadAssets(VersionDetail detail) throws IOException {
        // 下载asset index
        String assetIndexUrl = detail.assetIndex.url;
        String assetIndexId = detail.assetIndex.id;
        
        Path indexDir = ASSETS_DIR.resolve("indexes");
        Files.createDirectories(indexDir);
        Path indexFile = indexDir.resolve(assetIndexId + ".json");
        
        if (!Files.exists(indexFile)) {
            downloadFile(assetIndexUrl, indexFile);
        }
        
        // 解析并下载资源
        String indexJson = new String(Files.readAllBytes(indexFile), StandardCharsets.UTF_8);
        AssetIndex index = gson.fromJson(indexJson, AssetIndex.class);
        
        int total = index.objects.size();
        int current = 0;
        
        for (Map.Entry<String, AssetObject> entry : index.objects.entrySet()) {
            AssetObject obj = entry.getValue();
            String hash = obj.hash;
            String subHash = hash.substring(0, 2);
            String url = RESOURCES_BASE_URL + subHash + "/" + hash;
            
            Path target = ASSETS_DIR.resolve("objects").resolve(subHash).resolve(hash);
            if (!Files.exists(target)) {
                Files.createDirectories(target.getParent());
                try {
                    downloadFile(url, target);
                } catch (IOException e) {
                    log("资源下载失败（跳过）: " + hash);
                }
            }
            
            current++;
            if (current % 100 == 0) {
                setProgress(60 + (current * 30 / total));
            }
        }
    }
    
    private void extractNatives(VersionDetail detail, String versionId) throws IOException {
        Path nativeDir = NATIVES_DIR.resolve(versionId);
        Files.createDirectories(nativeDir);
        
        for (Library lib : detail.libraries) {
            if (!checkRules(lib.rules)) continue;
            if (lib.natives == null && (lib.extract == null)) continue;
            
            // 简化：只处理包含natives的库
            String path = lib.downloads.artifact.path;
            Path jarPath = LIBRARIES_DIR.resolve(path);
            
            if (Files.exists(jarPath)) {
                // 解压natives
                try (ZipInputStream zis = new ZipInputStream(Files.newInputStream(jarPath))) {
                    ZipEntry entry;
                    while ((entry = zis.getNextEntry()) != null) {
                        if (!entry.isDirectory() && !entry.getName().startsWith("META-INF")) {
                            Path target = nativeDir.resolve(entry.getName());
                            Files.copy(zis, target, StandardCopyOption.REPLACE_EXISTING);
                        }
                    }
                }
            }
        }
    }
    
